# Copy to .env and adjust before running docker compose
ENV=local

PROXY_PORT=8080
ADMIN_PORT=8081

# Admin user (seeded on first boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=EfPUB2QhcOk

# JWT for admin UI sessions (generate a strong random value for production)
JWT_SECRET=<your-jwt-secret>
JWT_TTL_HOURS=24

# SSO / OIDC — a provider is enabled only when both its CLIENT_ID and
# CLIENT_SECRET are set. Leave blank to disable. See docs/sso.md.
# Base URL the IdP redirects back to (callback = this + /api/v1/auth/oidc/{provider}/callback)
OIDC_REDIRECT_BASE_URL=http://localhost:8081
# Admin UI landing page after a successful browser SSO login
OIDC_FRONTEND_URL=http://localhost:5173
# Google Workspace
OIDC_GOOGLE_CLIENT_ID=235029044565-tob4faieusb8daomuofs7vjj49ca01c0.apps.googleusercontent.com
OIDC_GOOGLE_CLIENT_SECRET=<your-google-client-secret>
# Microsoft Entra ID / Azure AD
OIDC_MICROSOFT_CLIENT_ID=
OIDC_MICROSOFT_CLIENT_SECRET=
# Azure AD tenant: a tenant ID, or "common" / "organizations" / "consumers"
OIDC_MICROSOFT_TENANT=common

OTEL_COLLECTOR_ADDR=localhost:4317
OTEL_SERVICE_NAME=ai-gateway

REDIS_ADDR=localhost:6379

POSTGRES_DSN=postgres://gateway:gateway@localhost:6432/gateway?sslmode=disable

CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=otel
CLICKHOUSE_DB=otel

# Upstream LLM endpoints — add more blocks for fallback routing (N=0,1,2...)
UPSTREAM_0_KEY_ID=openai-primary
UPSTREAM_0_MODEL=gpt-4o
UPSTREAM_0_BASE_URL=https://api.openai.com
UPSTREAM_0_API_KEY=sk-...

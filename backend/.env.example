# Copy to .env and adjust before running docker compose
PROXY_PORT=8080
ADMIN_PORT=8081

OTEL_COLLECTOR_ADDR=localhost:4317
OTEL_SERVICE_NAME=ai-gateway

REDIS_ADDR=localhost:6379

POSTGRES_DSN=postgres://gateway:gateway@localhost:6432/gateway?sslmode=disable

# Upstream LLM endpoints — add more blocks for fallback routing (N=0,1,2...)
UPSTREAM_0_KEY_ID=openai-primary
UPSTREAM_0_MODEL=gpt-4o
UPSTREAM_0_BASE_URL=https://api.openai.com
UPSTREAM_0_API_KEY=sk-...

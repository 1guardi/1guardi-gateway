# Copy to .env.prod and fill in secrets before running docker compose

ENV=prod

PROXY_PORT=8080
ADMIN_PORT=8081

OTEL_SERVICE_NAME=ai-gateway

# ── SSO / OIDC ───────────────────────────────────────────────────────────────
# Public app host (gateway.theslmcompany.com). Callback the IdP redirects to =
# OIDC_REDIRECT_BASE_URL + /api/v1/auth/oidc/{provider}/callback — register that
# exact URI in the Google/Microsoft OAuth console. Defaults baked into compose.
OIDC_REDIRECT_BASE_URL=https://gateway.theslmcompany.com
OIDC_FRONTEND_URL=https://gateway.theslmcompany.com
# A provider is enabled only when both its CLIENT_ID and CLIENT_SECRET are set.
OIDC_GOOGLE_CLIENT_ID=
OIDC_GOOGLE_CLIENT_SECRET=
OIDC_MICROSOFT_CLIENT_ID=
OIDC_MICROSOFT_CLIENT_SECRET=
OIDC_MICROSOFT_TENANT=common

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=gateway
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=gateway

# ── Upstream LLM endpoints ────────────────────────────────────────────────────
# Add more UPSTREAM_N_* blocks for additional providers / fallback routing
UPSTREAM_0_KEY_ID=openai-primary
UPSTREAM_0_MODEL=gpt-4o
UPSTREAM_0_BASE_URL=https://api.openai.com
UPSTREAM_0_API_KEY=sk-...
